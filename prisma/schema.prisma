generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum Marketplace {
  EBAY_AU
  FACEBOOK
  GUMTREE
  AMAZON_AU
}

enum MatchType {
  EXACT
  CLOSE
  RELATED
  UNRELATED
}

enum WatchlistFrequency {
  WEEKLY
}

enum AlertType {
  MEDIAN_SHIFT
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  passwordHash String
  plan         Plan        @default(FREE)
  createdAt    DateTime    @default(now())
  scans        Scan[]
  watchlists   Watchlist[]
}

model Scan {
  id           String      @id @default(cuid())
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  watchlistId  String?
  watchlist    Watchlist?  @relation(fields: [watchlistId], references: [id], onDelete: SetNull)
  query        String
  category     String?
  location     String?
  userPrice    Int?
  marketplaces Marketplace[]
  status       ScanStatus  @default(PENDING)
  errorMessage String?
  createdAt    DateTime    @default(now())
  completedAt  DateTime?
  listings     Listing[]
  report       ScanReport?
  alerts       Alert[]

  @@index([userId, createdAt])
  @@index([watchlistId, createdAt])
}

model Listing {
  id              String      @id @default(cuid())
  scanId          String
  scan            Scan        @relation(fields: [scanId], references: [id], onDelete: Cascade)
  marketplace     Marketplace
  title           String
  price           Int
  currency        String      @default("AUD")
  condition       String?
  sellerName      String?
  location        String?
  listingUrl      String
  imageUrl        String?
  matchType       MatchType   @default(UNRELATED)
  matchConfidence Float       @default(0)
  rawData         Json
  extractedAt     DateTime    @default(now())

  @@index([scanId, matchConfidence])
}

model ScanReport {
  id                 String   @id @default(cuid())
  scanId             String   @unique
  scan               Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  avgPrice           Int
  medianPrice        Int
  minPrice           Int
  maxPrice           Int
  totalListings      Int
  platformBreakdown  Json
  pricePosition      Float?
  recommendation     Json?
  createdAt          DateTime @default(now())
}

model Watchlist {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  query        String
  location     String?
  userPrice    Int?
  marketplaces Marketplace[]
  frequency    WatchlistFrequency @default(WEEKLY)
  active       Boolean            @default(true)
  lastRunAt    DateTime?
  nextRunAt    DateTime
  createdAt    DateTime           @default(now())
  scans        Scan[]
  alerts       Alert[]

  @@index([active, nextRunAt])
  @@index([userId, createdAt])
}

model Alert {
  id          String    @id @default(cuid())
  watchlistId String
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  scanId      String
  scan        Scan      @relation(fields: [scanId], references: [id], onDelete: Cascade)
  alertType   AlertType @default(MEDIAN_SHIFT)
  message     String
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([watchlistId, createdAt])
}
